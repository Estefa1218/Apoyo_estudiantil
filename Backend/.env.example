# Configuración de Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sistema_pae

# Configuración de Correo (ejemplo con Gmail)
# Ver: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_app
EMAIL_FROM=tu_email@gmail.com

# Configuración de la Aplicación
NODE_ENV=development
PORT=3001

# Ruta base para archivos subidos
UPLOAD_DIR=./uploads

# Profesional por defecto (ID) - cambiar en producción
DEFAULT_PROFESSIONAL_ID=1

# Autenticación para el sistema de login
AUTH_PASSWORD=tu_contraseña_segura
AUTH_SECRET=tu_secreto_para_tokens
AUTH_TOKEN_EXPIRES_IN=3600
